# Telegram Bot Token (get from @BotFather on Telegram)
# Replace the placeholder with your real token in a local `.env` file.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# WeatherAPI key (set this locally; do NOT commit your real key)
WEATHER_API_KEY=YOUR_WEATHERAPI_KEY_HERE

# Optional: coordinates to monitor periodically (semicolon-separated list):
# Example: MONITOR_COORDS=59.91,10.75;40.71,-74.01
# If set, the background scheduler will fetch WeatherAPI data for these coords every WEATHER_FETCH_INTERVAL_MIN minutes.
MONITOR_COORDS=59.91,10.75
# Fetch interval in minutes (default 10)
WEATHER_FETCH_INTERVAL_MIN=10

# SECURITY NOTE:
# - Do NOT commit your real tokens to the repository.
# - Keep `.env` listed in .gitignore (already configured).