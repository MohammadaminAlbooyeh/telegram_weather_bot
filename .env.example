# Telegram Bot Token (get from @BotFather on Telegram)
# Replace the placeholder with your real token in a local `.env` file.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# OpenWeatherMap API Key (get from https://openweathermap.org/api)
# Replace the placeholder with your real API key in a local `.env` file.
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# SECURITY NOTE:
# - Do NOT commit your real tokens to the repository.
# - Keep `.env` listed in .gitignore (already configured).