# Telegram Bot Token (get from @BotFather on Telegram)
# Replace the placeholder with your real token in a local `.env` file.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# OpenWeather removed: this project no longer uses OpenWeatherMap.
# Use MET Norway or another provider; configure provider-specific keys as needed.

# Optional: coordinates to monitor periodically (semicolon-separated list):
# Example: MONITOR_COORDS=59.91,10.75;40.71,-74.01
# If set, the background scheduler will fetch MET Norway data for these coords every MET_FETCH_INTERVAL_MIN minutes.
MONITOR_COORDS=59.91,10.75
# Fetch interval in minutes (default 10)
MET_FETCH_INTERVAL_MIN=10

# SECURITY NOTE:
# - Do NOT commit your real tokens to the repository.
# - Keep `.env` listed in .gitignore (already configured).